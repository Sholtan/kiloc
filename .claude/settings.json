{
  "permissions": {
    "allow": [
      "Read(**)"
    ],
    "ask": [
      "Edit(**/*.md)",
      "Write(**/*.md)"
    ],
    "deny": [
      "Bash(rm*)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import sys, json; inp = json.load(sys.stdin); path = inp.get('path', inp.get('file_path', '')); sys.exit(0 if (not path or path.endswith('.md')) else 2)\""
          }
        ]
      }
    ]
  }
}